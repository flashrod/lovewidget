# ========================
DerivedData/
build/
.release/
*.ipa
*.dSYM.zip
*.dSYM
LoveWidget.app/
*.app

# ========================
# Swift Package Manager
# ========================
.build/
.swiftpm/
*.resolved

# ========================
# macOS
# ========================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

